# Generated by PCC workspace-configure workflow

# =============================================================================
# OS and Editor Files
# =============================================================================
**/.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-*

# =============================================================================
# Claude Code & BMAD
# =============================================================================
.claude/
.gemini/
.cursor/
.aider*

# BMAD — ignore core installation, track only PCC custom module
_bmad/*

# =============================================================================
# PCC Generated/Runtime
# =============================================================================
paw
paw_runner/*
requirements.txt
.pcc-deploy-manifest.yaml
.pcc-config.template.yaml

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
*.bak
*.backup
*.orig
*.rej
.~*

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
*.log.*

# =============================================================================
# Credentials and Secrets
# =============================================================================
.env
.env.local
*.key
*.pem
secrets/
credentials/

# =============================================================================
# Cache
# =============================================================================
.cache/
*.cache

# =============================================================================
# Node.js (doc tooling: Docusaurus, MkDocs, etc.)
# =============================================================================
node_modules/
package-lock.json
yarn.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Python (Sphinx, MkDocs, etc.)
# =============================================================================
__pycache__/
*.pyc
.venv/
venv/

# =============================================================================
# Documentation Build Output
# =============================================================================
_build/
site/
public/
dist/

# =============================================================================
# Draft/Scratch Files
# =============================================================================
drafts/
scratch/
temp/

# =============================================================================
# Test Results & Reports
# =============================================================================
performance/results/
!performance/results/.gitkeep

# =============================================================================
# Documentation (preserve tracked docs)
# =============================================================================
!docs/**/*.md
!docs/**/*.yaml
!docs/**/*.yml

# =============================================================================
# C++ Build Artifacts (workspace.gitignore_extras)
# =============================================================================
build/
build-*/
*.o
*.obj
*.exe
*.dll
*.lib
*.a
*.so
*.dylib
_deps/

